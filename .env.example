# StreamingCatalog uses a dedicated Chrome profile (not your normal one).
# By default it lives at ~/.streaming-catalog/chrome-profile.
# Override with an absolute path if you want it somewhere else:
# STREAMING_CATALOG_CHROME_PROFILE=/path/to/profile

# Database location (default: ./data/catalog.db)
# STREAMING_CATALOG_DB=./data/catalog.db

# Search UI port (default: 5858, can be set via `setup` prompt)
# STREAMING_CATALOG_PORT=5858
