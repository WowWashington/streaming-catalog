# Chrome profile directory (auto-detected per OS if unset)
# macOS: ~/Library/Application Support/Google/Chrome
# Windows: %LOCALAPPDATA%\Google\Chrome\User Data
# Linux: ~/.config/google-chrome
# STREAMING_CATALOG_CHROME_PROFILE=

# Chrome profile name (default: "Default")
# STREAMING_CATALOG_CHROME_PROFILE_NAME=Default

# Database location (default: ./data/catalog.db)
# STREAMING_CATALOG_DB=./data/catalog.db

# Search UI port (default: 5858)
# STREAMING_CATALOG_PORT=5858
