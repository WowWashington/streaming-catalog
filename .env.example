# StreamingCatalog keeps everything project-local by default:
#   ./chrome-profile/   (Chrome session for the collector)
#   ./data/             (catalog.db + collected ID files)
# Override any of the paths below if you want a different layout.

# Chrome user-data directory (default: ./chrome-profile)
# STREAMING_CATALOG_CHROME_PROFILE=/path/to/profile

# Database location (default: ./data/catalog.db)
# STREAMING_CATALOG_DB=/path/to/catalog.db

# Search UI port (default: 5858, also settable via `setup` prompt)
# STREAMING_CATALOG_PORT=5858
